rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Manager/admin have full write access.
    function hasWriteAccess() {
      return request.auth != null &&
             request.auth.token.role in ['manager', 'admin'];
    }

    // Minimal shape validation for full writes.
    function isValidGlobalState() {
      let data = request.resource.data;
      let hasAllRequiredFields = data.keys().hasAll(
        ['overrides', 'publishedOverrides', 'team', 'lastUpdated', 'config']
      );
      let fieldsAreValidType = (
        (!('overrides' in data) || data.overrides is map) &&
        (!('publishedOverrides' in data) || data.publishedOverrides is map) &&
        (!('team' in data) || data.team is list) &&
        (!('lastUpdated' in data) || data.lastUpdated is number) &&
        (!('config' in data) || data.config is map)
      );
      return request.writeFields.size() < 5
        ? fieldsAreValidType
        : (hasAllRequiredFields && fieldsAreValidType);
    }

    // Deny-by-default on every other document.
    match /{document=**} {
      allow read, write: if false;
    }

    // ============================================
    // Shift scheduler global state
    // ============================================
    // The schedule itself is non-sensitive (names are visible on the client
    // once authenticated); reads are public so the landing page can load.
    // All mutating paths require authentication and a role claim.
    //
    // IMPORTANT: password changes must go through the `changePassword`
    // Cloud Function (Admin SDK write) — client-side team edits are only
    // allowed for manager/admin, and the Cloud Function bypasses these
    // rules when acting as a service account.
    match /artifacts/{appId}/public/data/shift_scheduler/global_state {
      allow read: if true;

      // Manager/admin: full writes with basic shape validation.
      allow create, update: if hasWriteAccess() && isValidGlobalState();

      // Editor: append-only to the `requests` queue. Cannot touch `team`,
      // `overrides`, `publishedOverrides`, `config`, or any other field.
      allow update: if request.auth != null &&
                       request.auth.token.role == 'editor' &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['requests', 'lastUpdated']) &&
                       request.resource.data.requests is list &&
                       request.resource.data.requests.size()
                         > resource.data.requests.size();

      // Deletes are never allowed from the client.
      allow delete: if false;
    }
  }
}
