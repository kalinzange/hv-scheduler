# ============================================
# SECRETS & CREDENTIALS — never commit
# ============================================
# All env files (any location, any suffix) except templates
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.vault

# Randomly-named env backups that some editors / cloud sync tools create
*-*.env
*.env.bak
*.env.backup

# Firebase / GCP service account & admin credentials
.firebaserc
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
*service-account*.json
*serviceAccount*.json
*.credentials.json
*google-credentials*.json
*adminsdk*.json
*.pem
*.key
*.p12
*.pfx

# Any file that looks like a secret
secrets/
*.secret
*.secrets

# ============================================
# Firebase Functions
# ============================================
functions/lib/
functions/dist/
functions/node_modules/
functions/*.local
functions/.runtimeconfig.json
functions/tsconfig.dev.json
functions/src/generated/

# ============================================
# Python (Firebase Functions Python runtime)
# ============================================
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ============================================
# Dependencies
# ============================================
node_modules/

# ============================================
# Build outputs
# ============================================
dist/
dist-ssr/
build/
*.local
*.tsbuildinfo

# docs/ is the Vite build output. GitHub Pages is deployed via
# .github/workflows/deploy.yml (Pages source = "GitHub Actions"), which
# builds from source on the runner
docs/*

# ============================================
# Cache files
# ============================================
.eslintcache
.cache/
.parcel-cache/
.vite/

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/

# ============================================
# OS files
# ============================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================
# IDE / editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# AI/agent tooling (local state, not project config)
# ============================================
.agents/
.claude/
skills-lock.json

# ============================================
# Husky (project uses custom hooks/ folder instead)
# ============================================
.husky/

# ============================================
# Temporary files
# ============================================
*.tmp
*.bak
*.old
*.orig
