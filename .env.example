# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Cloud Function URL
# Get this after deploying functions: firebase deploy --only functions
# Format: https://us-central1-YOUR_PROJECT.cloudfunctions.net/roleLogin
VITE_CLOUD_FUNCTION_URL=https://us-central1-your_project.cloudfunctions.net/roleLogin

# App Configuration
VITE_APP_ID=your_app_identifier_here

# Google Calendar API Configuration
# Get your API key from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Select your project
# 3. Navigate to "APIs & Services" > "Credentials"
# 4. Click "Create Credentials" > "API Key"
# 5. (Recommended) Restrict the API key to "Google Calendar API" only
VITE_GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here