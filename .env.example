# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# Firebase App Check — reCAPTCHA v3 site key (public)
# Create a v3 site at https://www.google.com/recaptcha/admin
# Register the same key in Firebase Console > App Check > Web app
FIREBASE_APP_CHECK_SITE_KEY=your_recaptcha_v3_site_key_here

# Firebase Cloud Function URL
# Get this after deploying functions: firebase deploy --only functions
# Format: https://SELECTED_REGION-YOUR_PROJECT.cloudfunctions.net/roleLogin
CLOUD_FUNCTION_URL=https://selected_region-your_project.cloudfunctions.net/roleLogin

# App Configuration
APP_ID=your_app_identifier_here

# Google Calendar API Configuration
# Get your API key from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Select your project
# 3. Navigate to "APIs & Services" > "Credentials"
# 4. Click "Create Credentials" > "API Key"
# 5. (Recommended) Restrict the API key to "Google Calendar API" only
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here